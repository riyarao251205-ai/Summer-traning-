def student_result():
    name = input("enter name ")
    marks = []
    for i in range(1, 4):
            score = float(input("enter marks for subject "))
            marks.append(score)
    total = sum(marks)
    percentage = total / 3
    if any(m < 33 for m in marks):
        grade = "F"
        result = "Fail"
    else:
        result = "Pass"
        if percentage >= 90:
            grade = "A+"
        elif percentage >= 80:
            grade = "A"
        elif percentage >= 70:
            grade = "B"
        elif percentage >= 60:
            grade = "C"
        elif percentage >= 50:
            grade = "D"
        else:
            grade = "E"
    print(name)
    print( percentage)
    print(grade)
    print( result)
student_result()
